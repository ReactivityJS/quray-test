{
  "ociVersion": "1.0.2",
  "process": {
    "terminal": false,
    "user": { "uid": 0, "gid": 0 },
    "args": [
      "/usr/sbin/sshd", "-D", "-e",
      "-h", "/data/ssh/ssh_host_ed25519_key",
      "-h", "/data/ssh/ssh_host_rsa_key",
      "-o", "AuthorizedKeysFile=/data/ssh/authorized_keys"
    ],
    "env": [
      "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    ],
    "cwd": "/",
    "capabilities": {
      "bounding":  ["CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID","CAP_CHOWN","CAP_DAC_READ_SEARCH","CAP_AUDIT_WRITE"],
      "effective": ["CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID","CAP_CHOWN","CAP_DAC_READ_SEARCH","CAP_AUDIT_WRITE"],
      "permitted": ["CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID","CAP_CHOWN","CAP_DAC_READ_SEARCH","CAP_AUDIT_WRITE"],
      "ambient":   []
    }
  },
  "root": { "path": "rootfs" },
  "mounts": [
    { "destination": "/proc",    "type": "proc",      "source": "proc" },
    { "destination": "/dev",     "type": "devtmpfs",  "source": "devtmpfs" },
    { "destination": "/sys",     "type": "sysfs",     "source": "sysfs",
      "options": ["nosuid","noexec","nodev","ro"] },
    { "destination": "/tmp",     "type": "tmpfs",     "source": "tmpfs" },
    { "destination": "/run",     "type": "tmpfs",     "source": "tmpfs" },
    { "destination": "/data/ssh","type": "bind",      "source": "/data/ssh",
      "options": ["rbind","rw"] }
  ],
  "linux": {
    "namespaces": [
      { "type": "mount" },
      { "type": "uts" },
      { "type": "ipc" }
    ]
  }
}
