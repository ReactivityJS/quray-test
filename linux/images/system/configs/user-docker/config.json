{
  "ociVersion": "1.0.2",
  "process": {
    "terminal": false,
    "user": { "uid": 0, "gid": 0 },
    "args": [
      "/usr/local/bin/dockerd",
      "--host=unix:///var/run/docker.sock",
      "--storage-driver=overlay2",
      "--data-root=/var/lib/docker"
    ],
    "env": [
      "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    ],
    "cwd": "/",
    "capabilities": {
      "bounding":  ["CAP_CHOWN","CAP_DAC_OVERRIDE","CAP_DAC_READ_SEARCH","CAP_FSETID","CAP_FOWNER","CAP_MKNOD","CAP_NET_RAW","CAP_SETGID","CAP_SETUID","CAP_SETFCAP","CAP_SETPCAP","CAP_NET_BIND_SERVICE","CAP_SYS_CHROOT","CAP_KILL","CAP_AUDIT_WRITE","CAP_NET_ADMIN","CAP_SYS_ADMIN","CAP_SYS_MODULE","CAP_NET_BROADCAST","CAP_IPC_LOCK","CAP_SYS_PTRACE"],
      "effective": ["CAP_CHOWN","CAP_DAC_OVERRIDE","CAP_DAC_READ_SEARCH","CAP_FSETID","CAP_FOWNER","CAP_MKNOD","CAP_NET_RAW","CAP_SETGID","CAP_SETUID","CAP_SETFCAP","CAP_SETPCAP","CAP_NET_BIND_SERVICE","CAP_SYS_CHROOT","CAP_KILL","CAP_AUDIT_WRITE","CAP_NET_ADMIN","CAP_SYS_ADMIN","CAP_SYS_MODULE","CAP_NET_BROADCAST","CAP_IPC_LOCK","CAP_SYS_PTRACE"],
      "permitted": ["CAP_CHOWN","CAP_DAC_OVERRIDE","CAP_DAC_READ_SEARCH","CAP_FSETID","CAP_FOWNER","CAP_MKNOD","CAP_NET_RAW","CAP_SETGID","CAP_SETUID","CAP_SETFCAP","CAP_SETPCAP","CAP_NET_BIND_SERVICE","CAP_SYS_CHROOT","CAP_KILL","CAP_AUDIT_WRITE","CAP_NET_ADMIN","CAP_SYS_ADMIN","CAP_SYS_MODULE","CAP_NET_BROADCAST","CAP_IPC_LOCK","CAP_SYS_PTRACE"],
      "ambient":   []
    }
  },
  "root": { "path": "rootfs" },
  "mounts": [
    { "destination": "/proc",         "type": "proc",     "source": "proc" },
    { "destination": "/dev",          "type": "devtmpfs", "source": "devtmpfs" },
    { "destination": "/sys",          "type": "sysfs",    "source": "sysfs" },
    { "destination": "/dev/pts",      "type": "devpts",   "source": "devpts",
      "options": ["nosuid","noexec","newinstance","ptmxmode=0666","mode=0620"] },
    { "destination": "/tmp",          "type": "tmpfs",    "source": "tmpfs" },
    { "destination": "/run",          "type": "tmpfs",    "source": "tmpfs" },
    { "destination": "/var/run",      "type": "bind",     "source": "/var/run",
      "options": ["rbind","rshared"] },
    { "destination": "/var/lib/docker","type": "bind",    "source": "/data/user-docker",
      "options": ["rbind"] },
    { "destination": "/lib/modules",  "type": "bind",     "source": "/lib/modules",
      "options": ["rbind","ro"] }
  ],
  "linux": {
    "namespaces": [
      { "type": "mount" },
      { "type": "uts" },
      { "type": "ipc" }
    ]
  }
}
