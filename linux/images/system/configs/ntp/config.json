{
  "ociVersion": "1.0.2",
  "process": {
    "terminal": false,
    "user": { "uid": 0, "gid": 0 },
    "args": ["/usr/sbin/chronyd", "-d", "-f", "/etc/chrony/chrony.conf"],
    "env": [
      "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    ],
    "cwd": "/",
    "capabilities": {
      "bounding":  ["CAP_SYS_TIME","CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID"],
      "effective": ["CAP_SYS_TIME","CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID"],
      "permitted": ["CAP_SYS_TIME","CAP_NET_BIND_SERVICE","CAP_SETUID","CAP_SETGID"],
      "ambient":   []
    }
  },
  "root": { "path": "rootfs" },
  "mounts": [
    { "destination": "/proc", "type": "proc",     "source": "proc" },
    { "destination": "/dev",  "type": "devtmpfs", "source": "devtmpfs" },
    { "destination": "/sys",  "type": "sysfs",    "source": "sysfs",
      "options": ["nosuid","noexec","nodev","ro"] },
    { "destination": "/run",  "type": "tmpfs",    "source": "tmpfs" },
    { "destination": "/tmp",  "type": "tmpfs",    "source": "tmpfs" }
  ],
  "linux": {
    "namespaces": [
      { "type": "mount" },
      { "type": "uts" },
      { "type": "ipc" }
    ]
  }
}
