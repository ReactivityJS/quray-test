#!/bin/sh
# svc – OS-Service-Manager (wraps nerdctl)
# Jeder Service hat eine Definition in /usr/local/lib/svc-def/<name>.sh

SVC_DEF=/usr/local/lib/svc-def
action="${1:-}"; name="${2:-}"

_require() {
    [ -n "$name" ] || { echo "Usage: svc $action <name>"; exit 1; }
}

case "$action" in
    list)
        nerdctl ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Image}}"
        ;;
    status)
        _require
        nerdctl ps -a --filter "name=^${name}$" \
            --format "table {{.Names}}\t{{.Status}}\t{{.Image}}\t{{.RunningFor}}"
        ;;
    start)
        _require
        nerdctl start "$name"
        ;;
    stop)
        _require
        nerdctl stop "$name"
        ;;
    restart)
        _require
        nerdctl restart "$name"
        ;;
    log)
        _require
        nerdctl logs -f "$name"
        ;;
    enable)
        # Container neu anlegen (laut svc-def) falls nicht vorhanden
        _require
        def="$SVC_DEF/${name}.sh"
        [ -f "$def" ] || { echo "Keine Definition für: $name ($def)"; exit 1; }
        sh "$def"
        ;;
    disable)
        # Container stoppen und entfernen (restart-manager greift dann nicht mehr)
        _require
        nerdctl stop "$name" 2>/dev/null || true
        nerdctl rm   "$name" 2>/dev/null || true
        echo "$name: deaktiviert"
        ;;
    update)
        # Image aktualisieren und Container neu erstellen
        # Usage: svc update <name> [image:tag]
        _require
        def="$SVC_DEF/${name}.sh"
        [ -f "$def" ] || { echo "Keine Definition für: $name"; exit 1; }
        new_image="${3:-}"
        [ -n "$new_image" ] && nerdctl pull "$new_image"
        nerdctl stop "$name" 2>/dev/null || true
        nerdctl rm   "$name" 2>/dev/null || true
        sh "$def"
        echo "$name: aktualisiert"
        ;;
    exec)
        _require
        shift 2
        nerdctl exec -it "$name" "$@"
        ;;
    *)
        cat <<'USAGE'
svc <aktion> [name] [optionen]

  list                    Alle Container anzeigen
  status  <name>          Detailstatus eines Containers
  start   <name>          Container starten
  stop    <name>          Container stoppen
  restart <name>          Container neu starten
  log     <name>          Log-Stream (Ctrl+C zum Beenden)
  enable  <name>          Container anlegen/starten (laut svc-def)
  disable <name>          Container stoppen und entfernen
  update  <name> [image]  Image aktualisieren + Container neu erstellen
  exec    <name> [cmd...]  Befehl im Container ausführen
USAGE
        exit 1
        ;;
esac
