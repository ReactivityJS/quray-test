#!/bin/sh
set -e

log() {
    echo "[init] $*" >/dev/kmsg 2>/dev/null || echo "[init] $*"
}

# Basis-Filesystems
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t devtmpfs dev /dev 2>/dev/null || true
mkdir -p /dev/pts /dev/shm
mount -t devpts devpts /dev/pts 2>/dev/null || true
mount -t tmpfs tmpfs /dev/shm 2>/dev/null || true
mount -t tmpfs tmpfs /run
mkdir -p /run/containers /run/svc /run/crun

log "Filesystems mounted"

# State-Disk (/dev/vdb → /data)
mkdir -p /data
if ! blkid /dev/vdb 2>/dev/null | grep -q ext4; then
    log "Formatting state disk /dev/vdb..."
    mkfs.ext4 -q -L state /dev/vdb
fi
mount /dev/vdb /data
mkdir -p /data/ssh /data/user-docker

log "State disk mounted at /data"

# SSH-Keys – erster Boot oder nach Datenverlust
if [ ! -f /data/ssh/authorized_keys ]; then
    cp /etc/authorized_keys /data/ssh/authorized_keys
    chmod 600 /data/ssh/authorized_keys
fi
if [ ! -f /data/ssh/ssh_host_ed25519_key ]; then
    log "Generating SSH host keys..."
    ssh-keygen -q -t ed25519 -N '' -f /data/ssh/ssh_host_ed25519_key
    ssh-keygen -q -t rsa -b 4096 -N '' -f /data/ssh/ssh_host_rsa_key
fi

log "SSH keys ready"

# Netzwerk
ip link set lo up 2>/dev/null || true
for iface in eth0 net0 ens3; do
    ip link set "$iface" up 2>/dev/null || true
    udhcpc -i "$iface" -q -t 5 -n 2>/dev/null && log "DHCP ok on $iface" && break
done

log "Network configured"

# Bundles nach /run/containers kopieren (tmpfs, schreibbar für crun-State)
for svc in sshd ntp vmware firewall user-docker; do
    [ -d "/bundles/$svc" ] || continue
    cp -a "/bundles/$svc" "/run/containers/$svc"
done

log "Bundles prepared"

# Firewall einmalig ausführen (one-shot: setzt Regeln und beendet sich)
if [ -d /run/containers/firewall ]; then
    log "Applying firewall rules..."
    crun run --bundle /run/containers/firewall firewall 2>/dev/null || log "Firewall skipped"
    crun delete -f firewall 2>/dev/null || true
fi

# Supervise-Funktion: startet Container, neustart bei Fehler
supervise() {
    local name="$1"
    local bundle="/run/containers/$name"
    while true; do
        crun run --bundle "$bundle" "$name" >>/run/svc/"$name".log 2>&1 || true
        crun delete -f "$name" 2>/dev/null || true
        sleep 1
    done
}

# Services starten
for svc in vmware sshd ntp user-docker; do
    [ -d "/run/containers/$svc" ] || { log "Skipping $svc (no bundle)"; continue; }
    log "Starting $svc..."
    supervise "$svc" &
    echo $! >"/run/svc/$svc.pid"
done

log "System ready."

# PID-1 Wait-Loop: reapet Zombie-Prozesse
while true; do
    wait || true
done
